{
  "name": "osfui-frontend",
  "version": "0.0.0",
  "private": true,
  "description": "Source for the OSF UI built-in views. Builds to ../data/OSFUI/views (generated - never hand-edit).",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "verify": "npm run typecheck && npm run build && npm test",
    "check:dist": "node scripts/check-dist.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "preact": "10.29.7"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.10.6",
    "@types/node": "26.1.1",
    "acorn": "8.17.0",
    "ajv": "8.20.0",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
