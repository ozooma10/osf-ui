{
  "compilerOptions": {
    // Keep emitted syntax at the project's documented compatibility target.
    // Raising it is a deliberate output-contract change.
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    // The published SDK declaration file is the single source of truth for the
    // bridge protocol. src/lib/protocol.ts re-exports from it rather than
    // restating it, so the frontend and sdk/osfui.d.ts cannot drift apart -
    // a broken contract becomes a compile error, not a CI grep.
    "paths": {
      "@sdk": ["../sdk/osfui.d.ts"],
      "@lib/*": ["./src/lib/*"],
      "@ui/*": ["./src/ui/*"],
      "@views/*": ["./src/views/*"],
      "@harness/*": ["./harness/*"]
    },
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src", "harness", "test", "scripts", "vite.config.ts"],
  "exclude": [
    "node_modules",
    // Frozen public contract, shipped verbatim - described by osfui-global.d.ts,
    // never compiled.
    "src/shared-kit/osfui.js",
    "src/legacy/padnav.js"
  ]
}
