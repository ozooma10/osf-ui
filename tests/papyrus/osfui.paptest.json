{
  "$schema": "https://github.com/ozooma10/osf-ui/blob/main/docs/schema/settings-schema.schema.json",
  "id": "osfui.paptest",
  "title": "Papyrus API Test",
  "description": "Throwaway validation card for the OSFUI Papyrus natives (tests/papyrus/). Not shipped in releases.",
  "version": 1,

  "groups": [
    {
      "id": "general",
      "label": "General",
      "settings": [
        { "key": "enabled", "label": "Enabled", "type": "bool", "default": true },
        { "key": "count", "label": "Count", "type": "int", "min": 0, "max": 10, "default": 3 },
        { "key": "scale", "label": "Scale", "type": "float", "min": 0, "max": 2, "step": 0.05, "default": 1.0 },
        { "key": "mode", "label": "Mode", "type": "enum",
          "options": ["fast", "balanced", "quality"], "default": "balanced" },
        { "key": "label", "label": "Label", "type": "string", "default": "hello" }
      ]
    },
    {
      "id": "hotkeys",
      "label": "Hotkeys",
      "settings": [
        { "key": "testHotkey", "label": "Test hotkey", "type": "key", "default": "F8",
          "hint": "After cgf \"OSFUITest.RunAll\", press this in gameplay - a HUD notification should appear." }
      ]
    }
  ]
}
